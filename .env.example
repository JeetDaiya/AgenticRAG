# FinSight — Environment Variables Template
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file to git!
#
# cp .env.example .env

# =============================================================================
# LLM Provider — choose one and fill it in
# =============================================================================

# =============================================================================
# LLM Provider — OpenRouter
# =============================================================================

# OpenRouter gives you access to hundreds of models (free & paid) via one API key.
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# =============================================================================
# Web Search
# =============================================================================

# Tavily Search API (required for web_agent_node)
# Get your free key at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here
