# FinSight — Environment Variables Template
# Copy this file to .env and fill in your API keys.
# NEVER commit the .env file to git!
#
# cp .env.example .env

# =============================================================================
# LLM Provider — choose one and fill it in
# =============================================================================

# Option A: Google Gemini (Recommended — free, stable, great tool calling)
# Get your key at: https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Option B: Groq (Fast inference — use gemma2-9b-it or mixtral-8x7b-32768)
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# Web Search
# =============================================================================

# Tavily Search API (required for web_agent_node)
# Get your free key at: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here
